# ── Kalshi credentials ────────────────────────────────────────────────────────
# Generate at: https://kalshi.com/account/profile → API Keys
KALSHI_KEY_ID=your-key-id-here           # The Key ID shown after generation
KALSHI_KEY_FILE=kalshi.key               # Path to downloaded RSA private key file

# Demo overrides (used when KALSHI_DEMO=true)
# KALSHI_DEMO_KEY_ID=your-demo-key-id
# KALSHI_DEMO_KEY_FILE=kalshi-demo.key

# ── Polymarket credentials ─────────────────────────────────────────────────────
# Ethereum wallet private key for Polymarket CLOB auth (EIP-712 signing)
# Generate from your Polymarket account → API Keys / Connected wallet
POLY_PRIVATE_KEY=0xyour-eth-private-key-here
POLY_API_KEY=your-polymarket-api-key        # CLOB API key from Polymarket dashboard
POLY_API_SECRET=your-polymarket-api-secret
POLY_API_PASSPHRASE=your-polymarket-passphrase
POLY_CHAIN_ID=137                           # 137 = Polygon mainnet

# ── Environment ───────────────────────────────────────────────────────────────
KALSHI_DEMO=true          # true = use demo.kalshi.co  |  false = live trading
DRY_RUN=true              # true = log only, no real orders placed

# ── Market series ─────────────────────────────────────────────────────────────
SERIES_BTC=KXBTC15M
SERIES_ETH=KXETH15M
SERIES_SOL=KXSOL15M

# ── Position sizing ───────────────────────────────────────────────────────────
TRADE_SIZE_CONTRACTS=5    # contracts per entry (main + counter)
MAX_POSITION_CONTRACTS=20 # max total contracts held per market (unused)

# ── Momentum strategy ─────────────────────────────────────────────────────────
# Entry window: 13:00–14:00 of the 15-min window (780–840 s elapsed)
MOMENTUM_ENTRY_START=780
MOMENTUM_ENTRY_END=840

# Entry price range (cents).  Ask must be in [THRESHOLD, MAX) to enter.
# Lowered to 80c to give the 1:2 R:R more room to breathe.
MOMENTUM_ENTRY_THRESHOLD=80
MOMENTUM_ENTRY_MAX=95

# Retry: keep trying if price stays <= RETRY_MAX and we haven't filled
MOMENTUM_ENTRY_RETRY_MAX=90
MOMENTUM_ENTRY_RETRY_COOLDOWN=2.0   # seconds between retries

# ── Risk / Reward ─────────────────────────────────────────────────────────────
# 1:2 R:R — for every 1c risked, target 2c reward.
# SL is set dynamically at entry: sl = entry - (TP - entry) / RR_RATIO
#   e.g. entry 80c → reward 19c → risk 9.5c → SL 71c
#        entry 87c → reward 12c → risk  6c  → SL 81c
#        entry 95c → reward  4c → risk  2c  → SL 93c
MOMENTUM_RR_RATIO=2.0

# Take-profit target (cents).  Must reach this bid to sell before resolution.
# Pushed to 99c so the full resolution payout is the reward leg.
MOMENTUM_TAKE_PROFIT=99
MOMENTUM_TP_COOLDOWN=3.0

# Stop-loss cooldown (reactive SL fallback only — fires when no resting SL placed)
MOMENTUM_STOP_LOSS_COOLDOWN=3.0
# Minimum seconds after entry before reactive SL can fire (prevents hair-trigger)
MOMENTUM_SL_MIN_AGE=10.0

# ── Hedging (gated by HEDGING_ENABLED) ───────────────────────────────────────
HEDGING_ENABLED=true

# Entry hedge: buy N opposite contracts immediately after entry
MOMENTUM_ENTRY_HEDGE_COUNT=3

# Reversal hedge (last 60s): buy opposite if entry bid drops >= REVERSAL_DROP
MOMENTUM_REVERSAL_DROP=10
MOMENTUM_HEDGE_MIN_GAP=5           # opp ask must be <= (100 - entry - GAP)
MOMENTUM_HEDGE_COOLDOWN=3.0

# Warning hedge (last 30s): cheap insurance if bid reaches danger zone
MOMENTUM_WARN_THRESHOLD=75
MOMENTUM_WARN_COUNT=5
MOMENTUM_WARN_COOLDOWN=3.0

# Insurance hedge: buy N contracts if opposite ask collapses to <= threshold
MOMENTUM_INSURANCE_THRESHOLD=5
MOMENTUM_INSURANCE_COUNT=3
MOMENTUM_INSURANCE_COOLDOWN=3.0

# ── Counter-trade ─────────────────────────────────────────────────────────────
# Second entry on opposite side during 14:00–14:45 window (840–885 s elapsed)
MOMENTUM_COUNTER_START=840
MOMENTUM_COUNTER_END=885

# ── AI advisor (optional) ─────────────────────────────────────────────────────
AI_ADVISOR_ENABLED=false
AI_ADVISOR_LOOKBACK=20
AI_ADVISOR_MODEL=claude-haiku-4-5-20251001

# ── Arb strategy (cross-platform Kalshi × Polymarket) ────────────────────────
# Fire when YES_ask_A + NO_ask_B < ARB_THRESHOLD (cents).
# ±ARB_TOLERANCE accounts for fill slippage on both legs.
ARB_THRESHOLD=99           # combined cost must be below this (cents)
ARB_TOLERANCE=2            # accept fills up to this many cents above observed ask
ARB_TRADE_SIZE=5           # contracts per leg
ARB_MIN_PROFIT_CENTS=1     # skip if net profit after fees < this (cents)
ARB_ORDER_COOLDOWN=30      # seconds between order attempts (prevents rapid retries on Poly miss)
ARB_MAX_WINDOW_ENTRIES=2   # max arb entries per asset per 15-min window. Caps per-window exposure: a window that resolves oppositely loses ~N× a single arb. Each entry = ARB_TRADE_SIZE contracts.
ARB_MULTI_ORDER=true       # true=up to ARB_MAX_WINDOW_ENTRIES entries/window (each ARB_TRADE_SIZE). false=ONE entry/asset/window at ARB_SINGLE_ORDER_SIZE (A/B: one bigger trade vs several small).
ARB_SINGLE_ORDER_SIZE=5    # contracts for the single entry when ARB_MULTI_ORDER=false (>=5 Poly minimum). Defaults to ARB_TRADE_SIZE.
ARB_TRADES_CSV=arb_trades.csv  # clean CSV of SUCCESSFUL trades only (entries+exits) for easy review; trades.jsonl stays the full firehose.

# Basis-risk controls — Kalshi & Polymarket use different price feeds/strikes and
# can resolve OPPOSITELY when price settles near the strike (real −$3.63 loss on
# BTC). A 200-window study showed disagreements live within ~0.05% of strike.
ARB_ASSETS=ETH,SOL         # only trade these (BTC excluded — widest dead-zone)
ARB_STRIKE_BUFFER_PCT=0.20 # skip entry if |spot − Kalshi strike| < this % (venue-disagreement danger zone). % auto-scales per asset: 0.20%→ETH≈$3.6, SOL≈$0.28. Poly's strike (Chainlink-at-open) isn't in any feed, so we gate on distance from Kalshi's known strike + cross-feed headroom.
ARB_EXIT_BUFFER_PCT=0.05   # near expiry, sell BOTH legs if within this % of strike (0=hold)
ARB_EXIT_WINDOW_SECS=90    # early-exit only applies in the last N seconds

# Safety knobs (Phase 2)
ARB_K_SNAP_MAX_AGE=1.5     # max age of Kalshi snapshot before arb tick is skipped (s)
ARB_P_SNAP_MAX_AGE=1.5     # max age of Polymarket snapshot (WS-confirmed) before skip (s)
ARB_KALSHI_IOC_TIMEOUT=3.0 # HTTP timeout on Kalshi IOC inside arb (s); reconciles on timeout
ARB_UNWIND_RATIO_MAX=3.0   # abort if expected unwind loss > N × expected profit
ARB_STATS_INTERVAL=60      # seconds between per-window stats summary logs

# Naked-leg policy: if Poly fills but Kalshi misses, ALWAYS unwind the Poly leg.
ARB_POLY_HOLD_NAKED_USD=0      # 0 = always sell the naked Poly leg (never hold to resolution). >0 = hold legs whose buy-side cost is <= this USD.
POLY_UNWIND_MAX_ATTEMPTS=5     # balance-aware unwind: re-reads actual held shares each attempt & sells exactly that (handles ledger-lag/thin-book/settling). Incomplete after all attempts → log + CONTINUE (no halt).
POLY_UNWIND_ATTEMPT_DELAY=1.0  # seconds between unwind attempts

# Optional: force a specific Polymarket taker fee in basis points (e.g. 100 = 1%).
# When set, overrides both the CLOB /fee-rate endpoint and gamma takerBaseFee.
# Leave empty to use live rates (recommended for production).
POLY_FEE_BPS_OVERRIDE=

# ── Copy-trade scanner (Polymarket only, read-only) ──────────────────────────
# Feature flag — the whole scanner + forward-test executor is off unless true.
COPYTRADE_ENABLED=false
COPYTRADE_METRIC=profit          # profit | volume
COPYTRADE_WINDOW=all             # 1d | 7d | 30d | all
COPYTRADE_TOP_N=25               # leaderboard wallets to score
COPYTRADE_MAX_TRADE_USD=5000     # copyability gate: max avg trade size
COPYTRADE_REFRESH_SEC=300        # scanner poll interval
COPYTRADE_DEEP=true              # reconstruct lifetime realized winrate from /activity
COPYTRADE_MAX_EVENTS=1500        # per-wallet activity events scanned when deep

# ── Copy-trade forward-test executor (paper by default) ──────────────────────
# LIVE needs BOTH this env AND runtime mode=live; otherwise paper (simulated fill).
COPYTRADE_LIVE=false
COPYTRADE_EXEC_MAX_OPEN=20        # max concurrent open copies
COPYTRADE_EXEC_MAX_USD=5000       # only copy trades whose usdcSize <= this
COPYTRADE_EXEC_MIN_C=5            # hard price floor (cents)
COPYTRADE_EXEC_MAX_C=95           # hard price ceiling (cents)
COPYTRADE_EXEC_LOOKBACK=40        # activity events scanned per wallet per poll
COPYTRADE_EXEC_INTERVAL=60        # executor poll interval (seconds)
# COPYTRADE_FOLLOW=0xwallet1,0xwallet2   # optional: pin specific wallets to follow
# EV trade filter + risk sizing (the profitability levers):
COPYTRADE_EXEC_ENTRY_MAX_C=85    # skip deep favourites above this — payoff too asymmetric
# COPYTRADE_EXEC_ENTRY_MIN_C=5   # EV band floor (defaults to MIN_C)
COPYTRADE_EXEC_RISK_USD=5        # $ risked per copy; shares = RISK_USD/price (flat notional risk)
COPYTRADE_EXEC_MAX_SLIP_C=3      # reject copy if price ran more than this vs their fill
COPYTRADE_EXEC_MAX_SHARES=200    # hard share cap per copy (longshot blow-up guard)

# ── Files ─────────────────────────────────────────────────────────────────────
POSITIONS_FILE=positions.json
TRADES_FILE=trades.jsonl
LOG_FILE=kalshi_log.jsonl

# ── Weather NEAR-LOCK (Polymarket daily temperature markets) ──────────────────
WEATHER_ENABLED=true             # engine + paper forward-test on the dashboard
WEATHER_REFRESH_SEC=60           # discovery + METAR poll interval
WEATHER_P_MIN=0.92               # min model probability to enter
WEATHER_PRICE_MAX_C=82           # max ask (cents) — no chasing converged books
WEATHER_MIN_EDGE_C=8             # min (model_p*100 − ask) edge in cents
WEATHER_MIN_LOCAL_HOUR=13        # only trade once station-local afternoon underway
WEATHER_MAX_SPREAD_C=10          # skip books wider than this
WEATHER_STAKE_USD=5              # paper stake per position
WEATHER_MAX_OPEN=10              # max concurrent open positions
WEATHER_LIVE=false               # hard gate: live orders need this AND UI toggle
WEATHER_MIN_LOCAL_HOUR_LOW=10    # lows: daily min prints ~sunrise, unlocks earlier
